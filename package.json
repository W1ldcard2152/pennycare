{
  "name": "cvbooks",
  "version": "1.1.0",
  "description": "Payroll and bookkeeping management for small businesses",
  "author": "Certaverus Systems LLC",
  "license": "ISC",
  "main": "electron-dist/main.js",
  "scripts": {
    "dev": "dotenv -- next dev",
    "build": "next build --webpack",
    "start": "dotenv -- next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "npx tsx prisma/seed.ts",
    "electron:icon": "node electron/generate-icon.mjs",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:postbuild": "tsx electron/postbuild.ts",
    "electron:dev": "npm run build && npm run electron:icon && npm run electron:compile && npm run electron:postbuild && electron .",
    "electron:build": "npm run build && npm run electron:icon && npm run electron:compile && npm run electron:postbuild && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win"
  },
  "keywords": [],
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "crypto-js": "^4.2.0",
    "encoding": "^0.1.13",
    "jose": "^6.1.3",
    "jsonwebtoken": "^9.0.3",
    "next": "^16.1.4",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "prisma": "^6.19.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^3.7.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/bcryptjs": "^2.4.6",
    "@types/crypto-js": "^4.2.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.10",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "autoprefixer": "^10.4.23",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.4",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.6",
    "rcedit": "^5.0.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "com.cvbooks.app",
    "productName": "CV Books",
    "asar": false,
    "afterPack": "electron/after-pack.cjs",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron-dist/**/*",
      ".next/standalone/**/*",
      ".next/static/**/*",
      "public/**/*",
      "prisma/schema.prisma",
      "node_modules/@prisma/client/**/*",
      "node_modules/@prisma/engines/**/*",
      "node_modules/@prisma/debug/**/*",
      "node_modules/@prisma/fetch-engine/**/*",
      "node_modules/@prisma/get-platform/**/*",
      "node_modules/@prisma/internals/**/*",
      "node_modules/prisma/**/*",
      "!**/.bin/**"
    ],
    "extraResources": [
      {
        "from": "node_modules/.prisma",
        "to": "app/node_modules/.prisma"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "electron/icon.ico",
      "uninstallerIcon": "electron/icon.ico",
      "installerHeaderIcon": "electron/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CV Books"
    }
  }
}
